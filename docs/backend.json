
{
  "entities": {
    "Appointment": {
      "title": "Appointment",
      "description": "Um agendamento de serviço de cílios.",
      "type": "object",
      "properties": {
        "clientName": {
          "type": "string",
          "description": "Nome da cliente."
        },
        "serviceName": {
          "type": "string",
          "description": "Nome do estilo de cílios escolhido."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Data do agendamento."
        },
        "time": {
          "type": "string",
          "description": "Horário do agendamento."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Data e hora da criação do registro."
        }
      },
      "required": [
        "clientName",
        "serviceName",
        "date",
        "time"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "appointments/{appointmentId}": {
      "schema": "#/backend/entities/Appointment",
      "description": "Coleção de agendamentos realizados pelas clientes."
    }
  }
}
