
{
  "entities": {
    "Appointment": {
      "title": "Appointment",
      "description": "Agendamento de serviço.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { 
          "type": "string", 
          "enum": ["pendente", "confirmado", "finalizado", "cancelado"] 
        },
        "price": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientName", "serviceName", "date", "time", "status"]
    },
    "Client": {
      "title": "Client",
      "description": "Cadastro de cliente.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "birthday": { "type": "string" },
        "notes": { "type": "string" },
        "allergies": { "type": "string" },
        "totalSpent": { "type": "number" },
        "visitCount": { "type": "number" }
      }
    },
    "Service": {
      "title": "Service",
      "description": "Catálogo de serviços.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "string" },
        "description": { "type": "string" },
        "isActive": { "type": "boolean" },
        "imageUrl": { "type": "string" }
      }
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Controle de estoque.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "minThreshold": { "type": "number" },
        "category": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "appointments/{appointmentId}": { "schema": "#/backend/entities/Appointment", "description": "Agendamentos" },
    "clients/{clientId}": { "schema": "#/backend/entities/Client", "description": "CRM de Clientes" },
    "services/{serviceId}": { "schema": "#/backend/entities/Service", "description": "Catálogo" },
    "inventory/{itemId}": { "schema": "#/backend/entities/InventoryItem", "description": "Estoque" }
  }
}
